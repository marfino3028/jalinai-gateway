# ── Server ───────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# ── Free LLM Providers (isi minimal 1 biar gateway jalan) ──
# Groq  → https://console.groq.com/keys
GROQ_API_KEY=

# Google AI Studio (Gemini) → https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# OpenRouter → https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cloudflare Workers AI → https://dash.cloudflare.com (butuh account id + token)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=

# HuggingFace Inference → https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ── Gateway client API keys ───────────────────────────────
# Key dev default (tier ultimate) buat testing lokal
DEV_API_KEY=jln-dev-key

# Key produksi: JSON array. Contoh:
# GATEWAY_API_KEYS=[{"key":"jln-abc123","tier":"free","name":"toko-budi"},{"key":"jln-xyz789","tier":"pro","name":"toko-siti"}]
GATEWAY_API_KEYS=

# ── Rate limiting (req per menit) ─────────────────────────
FREE_RATE_LIMIT_PER_MIN=10
STARTER_RATE_LIMIT_PER_MIN=60
PRO_RATE_LIMIT_PER_MIN=120
ULTIMATE_RATE_LIMIT_PER_MIN=300

# ── Fase 4: Pricing & Token System ────────────────────────
DATA_DIR=./data
# Token super admin buat kelola key/harga/order (endpoint /admin/*)
ADMIN_TOKEN=jln-admin-dev

# Kuota token (free = harian, sisanya = bulanan)
FREE_TOKENS_PER_DAY=10000
STARTER_TOKENS_PER_MONTH=50000000
PRO_TOKENS_PER_MONTH=100000000
ULTIMATE_TOKENS_PER_MONTH=200000000

# Harga langganan (Rupiah/bulan)
PRICE_STARTER=15000
PRICE_PRO=25000
PRICE_ULTIMATE=50000

# Payment: manual (super admin approve) atau midtrans (Snap)
PAYMENT_PROVIDER=manual
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
APP_BASE_URL=http://localhost:8080
